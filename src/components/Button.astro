---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'nav';
  className?: string;
  [key: string]: any; // To allow for extra attributes like target, id, etc.
}

const { 
  href, 
  variant = 'primary', 
  className, 
  ...rest 
} = Astro.props;

const baseStyles = "px-7 font-semibold rounded-xl transition-colors duration-200 cursor-pointer";

const variants = {
  primary: "bg-neutral-950 text-white hover:bg-neutral-800 py-3.5",
  secondary: "bg-neutral-100 text-neutral-950 hover:bg-neutral-200 py-3.5",
  nav: "bg-neutral-950 text-white hover:bg-neutral-800 py-2",
};

const Element = href ? 'a' : 'button';
---

<Element 
  href={href} 
  class:list={[baseStyles, variants[variant], className]} 
  {...rest}
>
  <slot />
</Element>